# CatalystLens local environment template.
# Copy to .env (which is gitignored) and adjust as needed.
# `make up` works with these defaults; no real provider keys required.

# --- Postgres ---
POSTGRES_USER=catalystlens
POSTGRES_PASSWORD=catalystlens
POSTGRES_DB=catalystlens
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- API ---
API_PORT=8000
LOG_LEVEL=INFO

# Market data provider: "fixture" (default, no secrets) or "alpaca"
MARKET_DATA_PROVIDER=fixture

# Optional: only used when MARKET_DATA_PROVIDER=alpaca.
# Get a free paper-account key pair at https://alpaca.markets/
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_DATA_BASE_URL=https://data.alpaca.markets

# --- Web ---
WEB_PORT=3000
# Browser-facing API URL (legacy direct calls; prefer Next proxy below).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Server-side + Next.js rewrite target (run_local.sh sets http://127.0.0.1:8000).
API_BASE_URL_INTERNAL=http://127.0.0.1:8000
# docker-compose sets API_BASE_URL_INTERNAL=http://api:8000 for containers.
